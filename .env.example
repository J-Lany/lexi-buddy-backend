# Application
NODE_ENV=development
PORT=3000
APP_ENV=local
SERVICE_NAME=backend

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/lexi_buddy

# JWT
JWT_SECRET=your-jwt-secret-here

# AI (Qwen)
QWEN_API_KEY=your-qwen-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
MAIL_FROM=noreply@yourdomain.com
MAIL_LOGO_URL=https://your-cdn.com/icon.png

# Auth URLs (frontend)
ACTIVATION_URL=http://localhost:3001/activate
PASSWORD_CHANGE_URL=http://localhost:3001/confirm-password-change

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3001

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_INTERNAL_URL=http://localhost:4000
TELEGRAM_BOT_INTERNAL_TOKEN=your-internal-shared-secret

# S3 / Object Storage
S3_ENDPOINT=https://s3.your-provider.com
S3_REGION=ru-1
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_PUBLIC_BASE_URL=https://your-bucket.s3.your-provider.com
S3_AVATARS_PREFIX=avatars

# Admin
ADMIN_EMAILS=admin@yourdomain.com

# Seed (set to true only in development/staging)
SEED_TEST_DATA=false
