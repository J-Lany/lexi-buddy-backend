// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id Int @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Авторизационные данные
  passwordHash String? // null для Telegram-пользователей
  verified Boolean @default(false)

  // Глобальная роль
  role Role @relation(fields: [roleId], references: [id])
  roleId Int

  // Профиль (буду заполнять позже)
  firstName String?
  lastName String?
  level String?
  dateOfBirth DateTime?
  lastVisit DateTime?

  // Activation
  activationToken String?
  activationExpires DateTime?

  contacts UserContact[]
}

model Role {
  id Int @id @default(autoincrement())
  name String // teacher, student, assistant, admin
  description String?
  scope String // global, group
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model ContactType {
  id Int @id @default(autoincrement())
  name String // email, telegram, whatsapp ...
  displayName String?
  createdAt DateTime @default(now())

  userContacts UserContact[]
}

model UserContact {
  id Int @id @default(autoincrement())
  createdAt DateTime @default(now())

  contactValue  String
  isPrimary Boolean @default(false)
  verified Boolean @default(false)

  // Foreign keys
  user User @relation(fields: [userId], references: [id])
  userId Int

  contactType ContactType @relation(fields: [contactTypeId], references: [id])
  contactTypeId Int
}
